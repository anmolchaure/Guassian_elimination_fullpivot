)
# Plot the normal distribution
ggplot(df, aes(x = x, y = c)) +
geom_line(color = "steelblue", size = 1) +
geom_point(aes(x = 50, y = c), color = "red", size = 4) +  # Highlight your point
geom_vline(xintercept = 50, linetype = "dashed", color = "red", alpha = 0.5) +
labs(
title = "Normal Distribution (Diffusion Solution)",
x = "Position (x)",
y = "Concentration (c)",
subtitle = paste("D =", D, ", t =", t, ", q =", q)
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold", size = 14),
plot.subtitle = element_text(hjust = 0.5),
panel.grid.major = element_line(color = "gray90"),
panel.grid.minor = element_blank()
)
