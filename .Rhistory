df <- data.frame(t = t, c = c)
# Plot the normal distribution
ggplot(df, aes(x = x, y = c)) +
geom_line(color = "steelblue", size = 1) +
geom_point(aes(x = 50, y = c), color = "red", size = 3) +  # Highlight your point
labs(
title = "Normal Distribution",
x = "Position (x)",
y = "Concentration (c)",
subtitle = paste("D =", D, ", t =", t, ", q =", q)
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
plot.subtitle = element_text(hjust = 0.5)
)
# Plot the normal distribution
ggplot(df, aes(x = x, y = c)) +
geom_line(color = "steelblue", size = 1) +
geom_point(aes(x = 50, y = c), color = "red", linewidth = 3) +  # Highlight your point
labs(
title = "Normal Distribution",
x = "Position (x)",
y = "Concentration (c)",
subtitle = paste("D =", D, ", t =", t, ", q =", q)
) +
theme_minimal() +
theme(
